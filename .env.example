# ─── Database ────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:architext@localhost:5432/architext"

# ─── Authentication ──────────────────────────────────────────────
# Secret for better-auth session signing (generate with: openssl rand -base64 32)
AUTH_SECRET=""

# ─── Encryption ──────────────────────────────────────────────────
# 32-byte key for AES-256-GCM encryption of user API keys (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=""

# ─── App URL ─────────────────────────────────────────────────────
# Public URL of the app (used for OAuth callbacks and CORS)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Docker (only needed for docker-compose) ─────────────────────
POSTGRES_PASSWORD="architext"

# ─── OAuth (optional, not used in MVP bootstrap) ─────────────────
# OAUTH_GITHUB_ID=""
# OAUTH_GITHUB_SECRET=""
# OAUTH_GOOGLE_ID=""
# OAUTH_GOOGLE_SECRET=""

# ─── better-auth aliases ─────────────────────────────────────────
# These are set automatically from AUTH_SECRET and NEXT_PUBLIC_APP_URL
# BETTER_AUTH_SECRET is the same as AUTH_SECRET
# BETTER_AUTH_URL is the same as NEXT_PUBLIC_APP_URL
